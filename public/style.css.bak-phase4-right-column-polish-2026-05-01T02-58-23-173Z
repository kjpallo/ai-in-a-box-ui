  }

  .blade-page[data-blade-page="main"] .layout-grid {
    height: 100%;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(280px, 0.88fr) minmax(430px, 1.55fr) minmax(230px, 0.75fr);
    grid-template-rows: minmax(210px, 0.72fr) minmax(145px, 0.48fr);
    grid-template-areas:
      "question response voice"
      "question response history";
    gap: 0.55rem;
    align-items: stretch;
    overflow: hidden;
  }

  .blade-page[data-blade-page="main"] .panel {
    min-height: 0;
    border-radius: 18px;
  }

  .blade-page[data-blade-page="main"] .question-panel,
  .blade-page[data-blade-page="main"] .response-panel,
  .blade-page[data-blade-page="main"] .voice-panel,
  .blade-page[data-blade-page="main"] .history-panel {
    padding: 0.72rem;
    min-height: 0;
    overflow: hidden;
  }

  .blade-page[data-blade-page="main"] .question-panel {
    display: flex;
    flex-direction: column;
  }

  .blade-page[data-blade-page="main"] .panel-title-row {
    margin-bottom: 0.5rem;
    gap: 0.45rem;
  }

  .blade-page[data-blade-page="main"] .panel-title-row h2 {
    font-size: 0.78rem;
    line-height: 1.1;
    letter-spacing: 0.08em;
  }

  .blade-page[data-blade-page="main"] .status-pill,
  .blade-page[data-blade-page="main"] .stream-status {
    padding: 0.32rem 0.55rem;
    font-size: 0.68rem;
    line-height: 1;
  }

  .blade-page[data-blade-page="main"] .question-form {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .blade-page[data-blade-page="main"] #messageInput {
    flex: 1 1 auto;
    min-height: 0;
    height: auto;
    resize: none;
    padding: 0.85rem;
    border-radius: 16px;
    font-size: clamp(0.88rem, 0.95vw, 1rem);
    line-height: 1.35;
  }

  .blade-page[data-blade-page="main"] .button-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.45rem;
  }

  .blade-page[data-blade-page="main"] #sendButton,
  .blade-page[data-blade-page="main"] #stopAudioButton {
    width: 100%;
    padding: 0.72rem 0.8rem;
    font-size: 0.86rem;
  }

  .blade-page[data-blade-page="main"] .response-panel {
    display: flex;
    flex-direction: column;
    background: rgba(9, 21, 29, 0.96);
  }

  .blade-page[data-blade-page="main"] .response-actions {
    gap: 0.35rem;
    flex-wrap: nowrap;
  }

  .blade-page[data-blade-page="main"] .response-actions .small-button {
    padding: 0.36rem 0.52rem;
    font-size: 0.68rem;
    white-space: nowrap;
  }

  .blade-page[data-blade-page="main"] .response-text {
    flex: 1 1 auto;
    min-height: 0;
    height: auto;
    overflow: auto;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    font-size: clamp(1.02rem, 1.22vw, 1.36rem);
    line-height: 1.5;
  }

  .blade-page[data-blade-page="main"] .voice-panel {
    display: grid;
    place-items: center;
  }

  .blade-page[data-blade-page="main"] .voice-panel-inner {
    gap: 0.45rem;
    width: 100%;
    height: 100%;
    min-height: 0;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    place-items: center;
  }

  .blade-page[data-blade-page="main"] .voice-orb {
    width: min(100%, 190px);
    height: min(100%, 190px);
    max-width: 190px;
    max-height: 190px;
  }

  .blade-page[data-blade-page="main"] .orb-center-label {
    font-size: 0.78rem;
    line-height: 1.05;
  }

  .blade-page[data-blade-page="main"] .voice-status {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.2;
    text-align: center;
  }

  .blade-page[data-blade-page="main"] .history-panel {
    display: flex;
    flex-direction: column;
  }

  .blade-page[data-blade-page="main"] .history-panel .panel-title-row {
    margin-bottom: 0.4rem;
  }

  .blade-page[data-blade-page="main"] .history-list {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
    gap: 0.4rem;
    padding-right: 0.15rem;
  }

  .blade-page[data-blade-page="main"] .history-card {
    padding: 0.5rem 0.58rem;
    border-radius: 12px;
  }

  .blade-page[data-blade-page="main"] .history-question,
  .blade-page[data-blade-page="main"] .history-answer {
    font-size: 0.72rem;
    line-height: 1.22;
  }

  .blade-page[data-blade-page="main"] .history-answer {
    margin-top: 0.25rem;
  }

  .blade-page[data-blade-page="main"] .response-text,
  .blade-page[data-blade-page="main"] .history-list {
    scrollbar-width: thin;
    scrollbar-color: rgba(103,255,208,0.55) rgba(3,9,10,0.5);
  }

  .blade-page[data-blade-page="main"] .response-text::-webkit-scrollbar,
  .blade-page[data-blade-page="main"] .history-list::-webkit-scrollbar {
    width: 8px;
  }

  .blade-page[data-blade-page="main"] .response-text::-webkit-scrollbar-track,
  .blade-page[data-blade-page="main"] .history-list::-webkit-scrollbar-track {
    background: rgba(3,9,10,0.5);
    border-radius: 999px;
  }

  .blade-page[data-blade-page="main"] .response-text::-webkit-scrollbar-thumb,
  .blade-page[data-blade-page="main"] .history-list::-webkit-scrollbar-thumb {
    background: rgba(103,255,208,0.55);
    border-radius: 999px;
  }
}

@media (min-width: 980px) and (max-width: 1320px) {
  .blade-page[data-blade-page="main"] .layout-grid {
    grid-template-columns: minmax(250px, 0.85fr) minmax(360px, 1.45fr) minmax(190px, 0.7fr);
    gap: 0.45rem;
  }

  .blade-page[data-blade-page="main"] .app-header {
    min-height: 44px;
    padding: 0.42rem 0.55rem;
  }

  .blade-page[data-blade-page="main"] .subtitle {
    display: none;
  }

  .blade-page[data-blade-page="main"] .app-header {
    grid-template-areas: "eyebrow title";
    grid-template-columns: auto minmax(0, 1fr);
  }

  .blade-page[data-blade-page="main"] .voice-orb {
    width: min(100%, 150px);
    height: min(100%, 150px);
    max-width: 150px;
    max-height: 150px;
  }

  .blade-page[data-blade-page="main"] .response-actions {
    flex-wrap: wrap;
    justify-content: flex-end;
  }
}
