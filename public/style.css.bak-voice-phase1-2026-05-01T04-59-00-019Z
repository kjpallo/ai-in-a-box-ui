}

.system-light.yellow {
  background: #ffd166;
  box-shadow: 0 0 13px rgba(255, 209, 102, 0.75);
}

.system-light.red {
  background: #ff6f7f;
  box-shadow: 0 0 13px rgba(255, 111, 127, 0.8);
}

.system-check-copy {
  min-width: 0;
  display: grid;
  gap: 4px;
}

.system-check-copy strong {
  color: #f4fffb;
  font-size: 0.9rem;
}

.system-check-copy span {
  color: #b7d1cf;
  font-size: 0.82rem;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.system-check-copy summary {
  cursor: pointer;
  color: var(--neon);
  font-size: 0.76rem;
  font-weight: 900;
}

.system-check-copy pre {
  max-width: 100%;
  overflow: auto;
  margin: 6px 0 0;
  padding: 8px;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.35);
  color: #dfffee;
  font-size: 0.72rem;
}

@media (min-width: 980px) {
  html,
  body {
    height: 100%;
    overflow: hidden;
  }

  .blade-page:not([data-blade-page="main"]) .blade-page-body {
    overflow: auto;
  }
}

@media (min-width: 980px) and (max-width: 1400px) {
  .blade-ui-shell {
    grid-template-rows: minmax(0, 1fr) 72px;
    padding: 6px 8px;
  }

  .blade-stage-shell {
    grid-template-columns: minmax(0, 1fr) 96px 38px;
    gap: 6px;
  }

  .blade-center-panel {
    padding: 8px;
    border-radius: 22px;
  }

  .blade-page[data-blade-page="main"] .app-shell {
    grid-template-rows: 78px minmax(0, 1fr);
    gap: 8px;
  }

  .blade-page[data-blade-page="main"] .app-header {
    height: 78px;
    padding: 8px 18px;
    gap: 18px;
  }

  .brand-mark {
    width: 48px;
    border-radius: 16px;
  }

  .brand-copy h1 {
    font-size: 1.1rem;
    letter-spacing: 0.26em;
  }

  .eyebrow {
    font-size: 0.68rem;
  }

  .subtitle {
    min-height: 44px;
    padding: 0 18px;
    font-size: 0.64rem;
  }

  .header-sparkline {
    min-width: 170px;
  }

  .header-pill {
    min-height: 50px;
  }

  .header-pill {
    padding: 0 18px;
    font-size: 0.88rem;
  }

  .layout-grid {
    grid-template-columns: minmax(260px, 0.82fr) minmax(430px, 1.58fr) minmax(270px, 0.92fr);
    grid-template-rows: minmax(180px, 0.55fr) minmax(240px, 1fr);
    gap: 8px;
  }

  .question-panel,
  .response-panel,
  .history-panel,
  .voice-panel {
    padding: 14px;
    border-radius: 18px;
  }

  .panel-title-row {
    margin-bottom: 10px;
  }

  .panel-title-row h2 {
    font-size: 0.86rem;
  }

  #messageInput {
    padding: 16px;
  }

  #sendButton,
  .secondary-button,
  .voice-action-button {
    min-height: 46px;
    font-size: 0.82rem;
  }

  .response-text {
    padding: 24px;
    border-radius: 18px;
  }

  .answer-empty-state > p {
    margin-bottom: 34px;
  }

  .answer-feature-row {
    gap: 18px;
    padding-top: 28px;
  }

  .history-card {
    padding: 11px;
  }

  .history-question {
    font-size: 0.82rem;
  }

  .voice-content-row {
    padding: 12px;
    gap: 12px;
  }

  .voice-orb {
    max-width: 146px;
  }

  .blade-preview {
    width: 29px;
    border-radius: 16px;
  }

  .blade-preview-title {
    font-size: 0.66rem;
  }

  .blade-preview-icon {
    width: 22px;
  }

  .blade-bottom-nav {
    height: 66px;
    padding: 6px;
    gap: 8px;
  }

  .blade-nav-item,
  .blade-nav-arrow {
    min-height: 52px;
    border-radius: 14px;
  }

  .blade-nav-item {
    padding: 0 12px;
  }

  .blade-nav-label {
    font-size: 0.82rem;
  }
}

@media (max-width: 1120px) {
  body {
    overflow: auto;
  }

  .blade-ui-shell {
    height: auto;
    min-height: 100vh;
    overflow: visible;
  }

  .blade-stage-shell {
    grid-template-columns: minmax(0, 1fr);
  }

  .blade-preview-rail-right,
  .blade-arrow-right {
    display: none;
  }

  .blade-center-panel {
    overflow: visible;
  }

  .blade-page,
  .blade-page.active,
  .blade-main-content-wrap,
  .blade-page[data-blade-page="main"] .app-shell {
    height: auto;
    overflow: visible;
  }

  .app-header {
    grid-template-columns: 1fr;
    min-height: 0;
  }

  .status-center,
  .header-right {
    justify-content: start;
  }

  .layout-grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    grid-template-areas:
      "question"
      "response"
      "history"
      "voice";
    min-height: 0;
  }

  .question-panel {
    min-height: 460px;
  }

  .response-panel {
    min-height: 520px;
  }

  .history-panel,
  .voice-panel {
    min-height: 300px;
  }

  .blade-bottom-nav {
    grid-template-columns: 44px repeat(5, minmax(0, 1fr)) 44px;
    overflow-x: auto;
  }

  .blade-nav-label {
    font-size: 0.76rem;
  }
}

@media (max-width: 760px) {
  .app-shell {
    width: min(100% - 16px, 680px);
  }

  .status-center,
  .header-right,
  .button-row,
  .voice-placeholder-row,
  .answer-feature-row,
  .teacher-profile-grid,
  .teacher-profile-fields,
  .teacher-identity-card,
  .class-activity-top,
  .class-activity-bottom-grid,
  .system-health-grid,
  .system-health-summary,
  .ai-improvement-summary,
  .ai-improvement-toolbar,
  .ai-edit-fields,
  .ai-field-row,
  .voice-content-row {
    grid-template-columns: 1fr;
  }

  .header-right,
  .teacher-profile-top,
  .system-health-top,
  .profile-section-head {
    flex-direction: column;
    align-items: stretch;
  }

  .header-sparkline {
    min-width: 0;
  }

  .answer-feature-row {
    gap: 18px;
  }

  .profile-table-shell {
    overflow-x: auto;
  }

  .profile-table-head,
  .profile-table-row {
    min-width: 680px;
  }

  .blade-bottom-nav {
    grid-template-columns: 42px repeat(2, minmax(130px, 1fr)) 42px;
  }

  .blade-nav-item:nth-of-type(n+4) {
    display: none;
  }
}
