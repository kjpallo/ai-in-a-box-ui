:root {
  --bg: #030809;
  --panel: rgba(5, 15, 17, 0.9);
  --panel-strong: rgba(6, 18, 21, 0.96);
  --panel-border: rgba(88, 233, 204, 0.28);
  --panel-border-blue: rgba(110, 211, 255, 0.24);
  --panel-shadow: 0 22px 52px rgba(0, 0, 0, 0.42), 0 0 28px rgba(65, 255, 204, 0.1);
  --line: rgba(255, 255, 255, 0.08);
  --text: #edfdf8;
  --muted: #9eb8b6;
  --soft: #c8dfdc;
  --neon: #66f7d1;
  --neon-2: #7ee9ff;
  --answer-bg: #eef9fd;
  --answer-fg: #102b3a;
  --radius-lg: 22px;
  --radius-md: 16px;
  --radius-sm: 10px;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
}

body {
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 20% 0%, rgba(102, 247, 209, 0.14), transparent 30%),
    radial-gradient(circle at 78% 12%, rgba(126, 233, 255, 0.1), transparent 24%),
    linear-gradient(180deg, #061112 0%, var(--bg) 100%);
  color: var(--text);
  font-family: Inter, Arial, Helvetica, sans-serif;
}

button,
textarea,
select {
  font: inherit;
}

button {
  appearance: none;
  border: 0;
  cursor: pointer;
  transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
}

button:hover {
  transform: translateY(-1px);
}

button:active {
  transform: translateY(0);
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.58;
  transform: none;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Main app frame */
.app-shell {
  width: min(1360px, calc(100vw - 24px));
  margin: 0 auto;
  padding: 14px 0 20px;
}

.app-header {
  display: grid;
  grid-template-columns: minmax(270px, 0.95fr) minmax(340px, 1.2fr) minmax(190px, 0.55fr);
  align-items: center;
  gap: 26px;
  min-height: 96px;
  padding: 12px 22px;
  margin-bottom: 16px;
  border: 1px solid rgba(102, 247, 209, 0.22);
  border-radius: 20px;
  background:
    radial-gradient(circle at 3% 50%, rgba(102, 247, 209, 0.1), transparent 22%),
    linear-gradient(180deg, rgba(7, 18, 20, 0.95), rgba(3, 9, 11, 0.98));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 0 28px rgba(102, 247, 209, 0.08);
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 14px;
  min-width: 0;
}

.brand-mark {
  width: 56px;
  aspect-ratio: 1;
  border: 1px solid rgba(102, 247, 209, 0.55);
  border-radius: 18px;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 50% 35%, rgba(102, 247, 209, 0.35), transparent 48%),
    rgba(1, 15, 14, 0.85);
  box-shadow: 0 0 24px rgba(102, 247, 209, 0.3), inset 0 0 18px rgba(102, 247, 209, 0.12);
}

.brand-mark span {
  width: 28px;
  height: 32px;
  display: block;
  border: 3px solid var(--neon);
  border-top-left-radius: 12px;
  border-top-right-radius: 12px;
  clip-path: polygon(50% 0, 100% 25%, 88% 80%, 50% 100%, 12% 80%, 0 25%);
  box-shadow: 0 0 14px rgba(102, 247, 209, 0.5);
}

.brand-copy {
  min-width: 0;
}

.brand-copy h1 {
  margin: 0;
  color: #f4fffb;
  font-size: clamp(1.15rem, 1.7vw, 1.65rem);
  line-height: 1.05;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  text-shadow: 0 0 16px rgba(102, 247, 209, 0.16);
}

.eyebrow {
  margin: 7px 0 0;
  color: var(--neon);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  line-height: 1.1;
  text-transform: uppercase;
}

.status-center {
  display: grid;
  grid-template-columns: max-content minmax(180px, 1fr);
  gap: 22px;
  align-items: center;
  justify-content: center;
}

.subtitle {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  justify-content: center;
  min-height: 48px;
  margin: 0;
  padding: 0 24px;
  border: 1px solid rgba(102, 247, 209, 0.24);
  border-radius: 18px;
  background: rgba(8, 25, 28, 0.78);
  color: #b4c8c8;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
}

.subtitle span {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: var(--neon);
  box-shadow: 0 0 12px rgba(102, 247, 209, 0.85);
}

.header-sparkline {
  height: 38px;
  min-width: 220px;
  opacity: 0.92;
  background:
    linear-gradient(90deg, transparent 0 5%, rgba(102, 247, 209, 0.65) 5% 6%, transparent 6% 11%, rgba(126, 233, 255, 0.6) 11% 12%, transparent 12% 17%, rgba(102, 247, 209, 0.75) 17% 18%, transparent 18% 23%, rgba(102, 247, 209, 0.62) 23% 24%, transparent 24% 31%, rgba(126, 233, 255, 0.7) 31% 32%, transparent 32% 40%, rgba(102, 247, 209, 0.72) 40% 41%, transparent 41% 49%, rgba(102, 247, 209, 0.55) 49% 50%, transparent 50% 58%, rgba(126, 233, 255, 0.7) 58% 59%, transparent 59% 69%, rgba(102, 247, 209, 0.68) 69% 70%, transparent 70% 78%, rgba(102, 247, 209, 0.72) 78% 79%, transparent 79% 88%, rgba(126, 233, 255, 0.62) 88% 89%, transparent 89%),
    linear-gradient(120deg, transparent 0 4%, var(--neon) 4% 9%, transparent 9% 14%, var(--neon-2) 14% 19%, transparent 19% 24%, var(--neon) 24% 32%, transparent 32% 38%, var(--neon) 38% 46%, transparent 46% 52%, var(--neon-2) 52% 59%, transparent 59% 66%, var(--neon) 66% 72%, transparent 72% 80%, var(--neon) 80% 100%);
  mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
  clip-path: polygon(0 55%, 7% 55%, 9% 49%, 13% 57%, 18% 47%, 23% 52%, 27% 42%, 31% 48%, 36% 40%, 41% 51%, 47% 43%, 51% 57%, 56% 44%, 61% 52%, 67% 38%, 72% 58%, 77% 40%, 83% 47%, 89% 36%, 94% 48%, 100% 43%, 100% 58%, 0 58%);
  filter: drop-shadow(0 0 10px rgba(102, 247, 209, 0.35));
}

.header-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14px;
  min-width: 0;
}

.header-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-height: 58px;
  padding: 0 24px;
  border: 1px solid rgba(102, 247, 209, 0.22);
  border-radius: 19px;
  background: rgba(9, 24, 27, 0.78);
  color: var(--text);
  font-weight: 750;
  white-space: nowrap;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.classroom-view-pill span {
  width: 18px;
  height: 14px;
  display: inline-block;
  border: 2px solid rgba(215, 239, 240, 0.8);
  border-radius: 4px;
  position: relative;
}

.classroom-view-pill span::after {
  content: "";
  position: absolute;
  left: 4px;
  right: 4px;
  bottom: -6px;
  height: 2px;
  background: rgba(215, 239, 240, 0.8);
}

.layout-grid {
  display: grid;
  grid-template-columns: minmax(280px, 0.82fr) minmax(500px, 1.75fr) minmax(300px, 0.95fr);
  grid-template-rows: minmax(220px, 0.62fr) minmax(270px, 1fr);
  grid-template-areas:
    "question response history"
    "question response voice";
  gap: 10px;
  min-height: 620px;
}

.panel {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--panel-border);
  border-radius: var(--radius-lg);
  background:
    radial-gradient(circle at 50% 0%, rgba(102, 247, 209, 0.08), transparent 34%),
    linear-gradient(180deg, rgba(7, 23, 27, 0.94), rgba(2, 10, 12, 0.98));
  box-shadow: var(--panel-shadow), inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.panel::before {
  content: "";
  position: absolute;
  inset: 8px;
  border: 1px solid rgba(102, 247, 209, 0.12);
  border-radius: calc(var(--radius-lg) - 7px);
  pointer-events: none;
}

.question-panel {
  grid-area: question;
  display: flex;
  flex-direction: column;
  padding: 22px;
}

.response-panel {
  grid-area: response;
  display: flex;
  flex-direction: column;
  padding: 18px;
}

.history-panel {
  grid-area: history;
  display: flex;
  flex-direction: column;
  padding: 18px;
}

.voice-panel {
  grid-area: voice;
  display: flex;
  flex-direction: column;
  padding: 18px;
}

.panel-title-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 14px;
}

.panel-title-row h2 {
  margin: 0;
  color: #f5fffb;
  font-size: 1rem;
  line-height: 1.1;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.status-pill,
.stream-status,
.small-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  border: 1px solid rgba(102, 247, 209, 0.24);
  border-radius: 999px;
  background: rgba(8, 25, 28, 0.78);
  color: #d8fff3;
  font-size: 0.82rem;
  font-weight: 800;
  white-space: nowrap;
}

.status-pill,
.stream-status {
  padding: 0 14px;
  color: var(--neon);
}

.stream-status::before,
.status-pill::before {
  content: "";
  width: 7px;
  height: 7px;
  margin-right: 8px;
  border-radius: 999px;
  background: var(--neon);
  box-shadow: 0 0 10px rgba(102, 247, 209, 0.9);
}

.small-button {
  padding: 0 13px;
  border-color: rgba(255, 255, 255, 0.13);
  color: #f2fbff;
}

.secondary-small {
  color: #bfd3d3;
}

.response-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 8px;
}

.question-form {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

#messageInput {
  flex: 1;
  width: 100%;
  min-height: 0;
  resize: none;
  border: 1px solid rgba(126, 233, 255, 0.22);
  border-radius: 17px;
  outline: none;
  background: rgba(1, 9, 11, 0.72);
  color: var(--text);
  padding: 22px 22px;
  font-size: clamp(0.98rem, 1vw, 1.08rem);
  line-height: 1.45;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
}

#messageInput::placeholder {
  color: rgba(229, 244, 244, 0.48);
}

#messageInput:focus {
  border-color: rgba(102, 247, 209, 0.58);
  box-shadow: 0 0 0 4px rgba(102, 247, 209, 0.08);
}

.voice-controls {
  display: none;
}

.button-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
  gap: 14px;
}

.voice-placeholder-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

#sendButton,
.secondary-button,
.voice-action-button {
  min-height: 54px;
  border-radius: 999px;
  font-size: 0.92rem;
  font-weight: 900;
}

#sendButton {
  color: #061314;
  background: linear-gradient(135deg, #8df7ff, #41dfac);
  box-shadow: 0 0 24px rgba(102, 247, 209, 0.3);
}

#sendButton::before {
  content: ">";
  margin-right: 9px;
  font-weight: 900;
  transform: rotate(-24deg);
}

.secondary-button {
  border: 1px solid rgba(255, 255, 255, 0.14);
  color: #f3faf8;
  background: linear-gradient(180deg, rgba(42, 48, 52, 0.92), rgba(22, 25, 28, 0.98));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.11);
}

.secondary-button::before {
  content: "";
  width: 14px;
  height: 14px;
  margin-right: 10px;
  border-radius: 2px;
  background: #f3faf8;
}

.voice-action-button {
  border: 1px solid rgba(126, 233, 255, 0.2);
  background: rgba(8, 25, 28, 0.72);
  color: #dffcf7;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
}

.voice-action-button::before {
  content: "";
  width: 8px;
  height: 8px;
  margin-right: 9px;
  border-radius: 999px;
  background: rgba(126, 233, 255, 0.72);
  box-shadow: 0 0 10px rgba(126, 233, 255, 0.38);
}

.voice-action-button.is-active,
.voice-action-button[aria-pressed="true"] {
  border-color: rgba(102, 247, 209, 0.46);
  background: rgba(48, 133, 105, 0.34);
  color: #f5fffb;
}

.voice-action-button.is-active::before,
.voice-action-button[aria-pressed="true"]::before {
  background: var(--neon);
  box-shadow: 0 0 13px rgba(102, 247, 209, 0.8);
}

.voice-placeholder-status {
  min-height: 18px;
  margin: -8px 2px 0;
  color: #93aaa9;
  font-size: 0.78rem;
  line-height: 1.35;
}

.response-text {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  overflow: auto;
  border: 1px solid rgba(126, 233, 255, 0.35);
  border-radius: 20px;
  background:
    radial-gradient(circle at 55% 32%, rgba(255, 255, 255, 0.96), rgba(237, 247, 251, 0.94) 42%, rgba(220, 235, 242, 0.94) 100%);
  color: var(--answer-fg);
  padding: 32px 36px;
  font-size: clamp(1rem, 1.15vw, 1.18rem);
  line-height: 1.58;
  white-space: pre-wrap;
  box-shadow: 0 0 30px rgba(126, 233, 255, 0.18), inset 0 0 0 1px rgba(255, 255, 255, 0.58);
}

.response-empty {
  display: grid;
  place-items: center;
  white-space: normal;
}

.response-text.has-answer,
.response-text.streaming {
  display: block;
  white-space: pre-wrap;
}

.response-text.streaming::after {
  content: "|";
  display: inline-block;
  margin-left: 4px;
  animation: blink 0.9s steps(1) infinite;
}

.answer-empty-state {
  display: grid;
  justify-items: center;
  width: min(680px, 100%);
  text-align: center;
  color: var(--answer-fg);
}

.answer-empty-spark {
  width: 64px;
  height: 64px;
  margin-bottom: 18px;
  opacity: 0.58;
  background:
    radial-gradient(circle at 30% 62%, #ffffff 0 4px, transparent 5px),
    radial-gradient(circle at 62% 34%, #ffffff 0 4px, transparent 5px);
  position: relative;
}

.answer-empty-spark::before,
.answer-empty-spark::after {
  content: "";
  position: absolute;
  border: 1px solid rgba(255, 255, 255, 0.9);
  transform: rotate(45deg);
}

.answer-empty-spark::before {
  width: 26px;
  height: 26px;
  left: 28px;
  top: 6px;
}

.answer-empty-spark::after {
  width: 18px;
  height: 18px;
  left: 10px;
  top: 30px;
}

.answer-empty-state h3 {
  margin: 0;
  font-size: clamp(1.45rem, 2vw, 2rem);
  line-height: 1.1;
}

.answer-empty-state > p {
  max-width: 440px;
  margin: 18px 0 48px;
  color: #4f6b7c;
  font-size: 1rem;
  line-height: 1.55;
}

.answer-feature-row {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 30px;
  padding-top: 36px;
  border-top: 1px solid rgba(66, 94, 106, 0.16);
}

.answer-feature {
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr);
  gap: 13px;
  align-items: start;
  text-align: left;
}

.answer-feature > span {
  color: #14374c;
  font-size: 1.38rem;
  line-height: 1;
}

.answer-feature strong,
.answer-feature small {
  display: block;
}

.answer-feature strong {
  color: #153149;
  font-size: 0.9rem;
}

.answer-feature small {
  margin-top: 5px;
  color: #617b89;
  font-size: 0.78rem;
  line-height: 1.35;
}

.history-list {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  display: grid;
  gap: 10px;
  overflow: auto;
  padding-right: 2px;
}

.history-empty {
  margin: 0;
  color: var(--muted);
}

.history-card {
  display: grid;
  grid-template-columns: 24px minmax(0, 1fr);
  gap: 12px;
  align-items: start;
  padding: 14px;
  border: 1px solid rgba(126, 233, 255, 0.16);
  border-radius: 12px;
  background: rgba(6, 18, 22, 0.76);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.history-icon {
  width: 18px;
  height: 18px;
  border: 2px solid var(--neon);
  border-radius: 5px;
  position: relative;
  margin-top: 2px;
}

.history-icon::after {
  content: "";
  position: absolute;
  left: 3px;
  bottom: -5px;
  width: 6px;
  height: 6px;
  border-left: 2px solid var(--neon);
  border-bottom: 2px solid var(--neon);
  transform: skewY(-32deg);
}

.history-question,
.history-answer {
  margin: 0;
  line-height: 1.3;
}

.history-question {
  color: #eefaf8;
  font-size: 0.92rem;
}

.history-answer {
  margin-top: 8px;
  color: #9db2b4;
  font-size: 0.78rem;
}

.voice-panel-inner {
  position: relative;
  z-index: 1;
  flex: 1;
  min-height: 0;
  display: grid;
}

.voice-content-row {
  display: grid;
  grid-template-columns: minmax(130px, 0.95fr) minmax(140px, 1fr);
  gap: 18px;
  align-items: center;
  min-height: 0;
  border: 1px solid rgba(126, 233, 255, 0.12);
  border-radius: 14px;
  padding: 18px;
  background: rgba(3, 11, 13, 0.52);
}

.voice-wave-wrap {
  position: relative;
  display: grid;
  place-items: center;
  min-width: 0;
}

.voice-wave-wrap::before,
.voice-wave-wrap::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 44%;
  height: 36px;
  transform: translateY(-50%);
  background: linear-gradient(90deg, transparent, var(--neon), transparent);
  clip-path: polygon(0 48%, 9% 43%, 14% 55%, 19% 39%, 25% 57%, 31% 44%, 38% 52%, 44% 42%, 52% 57%, 59% 39%, 67% 52%, 74% 46%, 81% 56%, 88% 43%, 100% 49%, 100% 53%, 0 53%);
  filter: drop-shadow(0 0 9px rgba(102, 247, 209, 0.5));
  opacity: 0.85;
}

.voice-wave-wrap::before {
  right: 56%;
}

.voice-wave-wrap::after {
  left: 56%;
}

.voice-orb {
  position: relative;
  width: min(100%, 172px);
  max-width: 172px;
  aspect-ratio: 1;
  display: grid;
  place-items: center;
  isolation: isolate;
}

.orb-ring {
  position: absolute;
  border-radius: 999px;
  border: 1px solid rgba(102, 247, 209, 0.35);
  box-shadow: 0 0 28px rgba(102, 247, 209, 0.16), inset 0 0 36px rgba(102, 247, 209, 0.08);
}

.orb-ring-one {
  inset: 0;
}

.orb-ring-two {
  inset: 12px;
  border-color: rgba(241, 159, 76, 0.28);
}

.orb-core {
  position: relative;
  width: 72%;
  height: 72%;
  border-radius: 999px;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 40%, rgba(102, 247, 209, 0.42), transparent 32%),
    radial-gradient(circle at 50% 50%, rgba(241, 159, 76, 0.14), transparent 62%),
    #020506;
  border: 2px solid rgba(102, 247, 209, 0.45);
  box-shadow: 0 0 28px rgba(102, 247, 209, 0.24), 0 0 60px rgba(102, 247, 209, 0.12);
}

.voice-visualizer {
  width: 100%;
  height: 100%;
  display: block;
}

.orb-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 50%, transparent 0 46%, rgba(0, 0, 0, 0.4) 76%),
    repeating-radial-gradient(circle at 50% 50%, rgba(102, 247, 209, 0.12) 0 1px, transparent 1px 5px);
}

.orb-center-label {
  position: absolute;
  display: grid;
  gap: 2px;
  text-align: center;
  color: #f4fffb;
  font-size: 0.84rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  line-height: 1.1;
  text-transform: uppercase;
  text-shadow: 0 0 14px rgba(0, 0, 0, 0.75);
  pointer-events: none;
}

.voice-copy {
  display: grid;
  gap: 12px;
  align-content: center;
}

.voice-copy strong {
  color: #f6fffb;
  font-size: 0.9rem;
  line-height: 1.25;
}

.voice-status {
  margin: 0;
  color: #9fb4b6;
  font-size: 0.82rem;
  line-height: 1.45;
}

.voice-orb.speaking .orb-ring-one {
  animation: pulseOuter 1s ease-in-out infinite;
}

.voice-orb.speaking .orb-ring-two {
  animation: pulseInner 0.8s ease-in-out infinite;
}

.voice-orb.speaking .orb-core {
  animation: coreBreathe 0.75s ease-in-out infinite;
}

.tts-speaking .header-sparkline {
  animation: headerSparklineTalk 760ms ease-in-out infinite;
  filter: drop-shadow(0 0 14px rgba(102, 247, 209, 0.62));
}

.tts-speaking .voice-wave-wrap::before,
.tts-speaking .voice-wave-wrap::after {
  animation: sideWaveTalk 680ms ease-in-out infinite;
}

.tts-speaking .voice-wave-wrap::after {
  animation-delay: 120ms;
}

.tts-speaking .voice-orb .orb-overlay {
  animation: orbDisturbance 900ms linear infinite;
}

.voice-orb.idle .orb-ring-one,
.voice-orb.idle .orb-ring-two {
  animation: idleGlow 4s ease-in-out infinite;
}

@keyframes pulseOuter {
  50% {
    transform: scale(1.04);
    box-shadow: 0 0 42px rgba(102, 247, 209, 0.32), inset 0 0 48px rgba(102, 247, 209, 0.12);
  }
}

@keyframes pulseInner {
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
}

@keyframes coreBreathe {
  50% {
    transform: scale(1.03);
  }
}

@keyframes idleGlow {
  50% {
    opacity: 0.72;
  }
}

@keyframes headerSparklineTalk {
  0%,
  100% {
    opacity: 0.88;
    transform: scaleY(0.82);
    clip-path: polygon(0 55%, 7% 55%, 9% 49%, 13% 57%, 18% 47%, 23% 52%, 27% 42%, 31% 48%, 36% 40%, 41% 51%, 47% 43%, 51% 57%, 56% 44%, 61% 52%, 67% 38%, 72% 58%, 77% 40%, 83% 47%, 89% 36%, 94% 48%, 100% 43%, 100% 58%, 0 58%);
  }
  50% {
    opacity: 1;
    transform: scaleY(1.1);
    clip-path: polygon(0 54%, 6% 48%, 10% 63%, 15% 35%, 20% 60%, 25% 42%, 30% 68%, 36% 30%, 42% 58%, 48% 36%, 53% 66%, 59% 31%, 64% 58%, 70% 39%, 75% 70%, 80% 32%, 86% 56%, 91% 28%, 96% 61%, 100% 41%, 100% 60%, 0 60%);
  }
}

@keyframes sideWaveTalk {
  50% {
    opacity: 1;
    transform: translateY(-50%) scaleX(1.08) scaleY(1.28);
    filter: drop-shadow(0 0 14px rgba(102, 247, 209, 0.78));
  }
}

@keyframes orbDisturbance {
  0% {
    transform: rotate(0deg) scale(1);
    opacity: 0.8;
  }
  50% {
    transform: rotate(2deg) scale(1.04);
    opacity: 1;
  }
  100% {
    transform: rotate(0deg) scale(1);
    opacity: 0.82;
  }
}

@keyframes blink {
  50% {
    opacity: 0;
  }
}

/* Blade shell */
.blade-ui-shell {
  height: 100vh;
  min-height: 100vh;
  display: grid;
  grid-template-rows: minmax(0, 1fr) 82px;
  gap: 8px;
  padding: 8px 10px;
  overflow: hidden;
}

.blade-stage-shell {
  min-height: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 112px 44px;
  gap: 8px;
  align-items: stretch;
  position: relative;
}

.blade-side-frame-left,
.blade-preview-rail-left,
.blade-arrow-left {
  display: none;
}

.blade-center-stage {
  min-height: 0;
  display: grid;
  place-items: stretch;
  position: relative;
}

.blade-center-halo {
  position: absolute;
  inset: 1% 2%;
  border-radius: 30px;
  background: radial-gradient(circle at top center, rgba(102, 247, 209, 0.08), transparent 45%);
  filter: blur(8px);
  pointer-events: none;
}

.blade-center-panel {
  position: relative;
  min-height: 0;
  overflow: hidden;
  padding: 10px;
  border: 1px solid rgba(102, 247, 209, 0.26);
  border-radius: 24px;
  background:
    radial-gradient(circle at top center, rgba(102, 247, 209, 0.07), transparent 36%),
    linear-gradient(180deg, rgba(7, 18, 20, 0.94), rgba(2, 8, 10, 0.98));
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5), 0 0 34px rgba(102, 247, 209, 0.13);
}

.blade-page {
  display: none;
  height: 100%;
  min-height: 0;
  overflow: hidden;
  animation: bladePageIn 180ms ease;
}

.blade-page.active {
  display: block;
}

.blade-page-title {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  margin: 0 0 10px;
  padding: 0 14px;
  border: 1px solid rgba(102, 247, 209, 0.2);
  border-radius: 999px;
  background: rgba(102, 247, 209, 0.11);
  color: #f4fffb;
  font-size: 1rem;
  font-weight: 900;
}

.blade-page-body {
  height: calc(100% - 44px);
  min-height: 0;
  overflow: auto;
  color: var(--text);
}

.blade-main-content-wrap {
  height: 100%;
  min-height: 0;
  overflow: hidden;
}

.blade-main-content-wrap > * {
  width: 100%;
}

.blade-page[data-blade-page="main"] > .blade-page-title {
  display: none;
}

.blade-page[data-blade-page="main"] .app-shell {
  width: 100%;
  max-width: none;
  height: 100%;
  min-height: 0;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-rows: 90px minmax(0, 1fr);
  gap: 10px;
  overflow: hidden;
}

.blade-page[data-blade-page="main"] .app-header {
  min-height: 0;
  height: 90px;
  margin: 0;
}

.blade-page[data-blade-page="main"] .layout-grid {
  min-height: 0;
  height: 100%;
  overflow: hidden;
}

.blade-page[data-blade-page="main"] .question-panel,
.blade-page[data-blade-page="main"] .response-panel,
.blade-page[data-blade-page="main"] .history-panel,
.blade-page[data-blade-page="main"] .voice-panel {
  min-height: 0;
}

.blade-preview-rail-right {
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 6px;
  min-width: 0;
  min-height: 0;
}

.blade-preview {
  width: 34px;
  min-width: 0;
  height: 100%;
  padding: 0;
  border: 1px solid rgba(102, 247, 209, 0.24);
  border-radius: 18px;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
    linear-gradient(180deg, rgba(43, 55, 57, 0.9), rgba(6, 15, 16, 0.98));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 0 22px rgba(102, 247, 209, 0.16);
}

.blade-preview-inner {
  height: 100%;
  min-height: 0;
  display: grid;
  grid-template-rows: 1fr auto 1fr;
  justify-items: center;
  align-items: center;
  padding: 10px 2px;
  overflow: hidden;
}

.blade-preview-title {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  color: rgba(241, 255, 250, 0.94);
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  line-height: 1;
  text-transform: uppercase;
}

.blade-preview-icon {
  width: 24px;
  aspect-ratio: 1;
  display: grid;
  place-items: center;
  border: 1px solid rgba(102, 247, 209, 0.28);
  border-radius: 999px;
  color: var(--neon);
  background: rgba(102, 247, 209, 0.08);
  font-size: 0.68rem;
  font-weight: 900;
}

.blade-preview-accent {
  width: 70%;
  height: 44px;
  border-radius: 999px;
  background: radial-gradient(circle at center, rgba(102, 247, 209, 0.32), transparent 70%);
}

.blade-arrow {
  align-self: center;
  width: 42px;
  height: 54px;
  border: 1px solid rgba(102, 247, 209, 0.22);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(24, 32, 34, 0.96), rgba(7, 12, 13, 0.98));
  color: #f5fffb;
  font-size: 1.6rem;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 0 20px rgba(102, 247, 209, 0.12);
}

.blade-side-frame-right {
  display: none;
}

.blade-bottom-nav {
  display: grid;
  grid-template-columns: 52px repeat(5, minmax(0, 1fr)) 52px;
  gap: 10px;
  align-items: center;
  margin: 0;
  padding: 8px;
  border: 1px solid rgba(102, 247, 209, 0.22);
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(11, 24, 25, 0.96), rgba(3, 9, 10, 0.98));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 0 24px rgba(102, 247, 209, 0.12);
}

.blade-nav-item,
.blade-nav-arrow {
  min-height: 58px;
  border: 1px solid rgba(102, 247, 209, 0.18);
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(22, 33, 35, 0.88), rgba(6, 12, 13, 0.98));
  color: #f1fffa;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.blade-nav-arrow {
  font-size: 1.55rem;
}

.blade-nav-item {
  display: grid;
  grid-template-columns: 30px minmax(0, 1fr);
  gap: 10px;
  align-items: center;
  justify-items: start;
  padding: 0 18px;
  font-weight: 900;
}

.blade-nav-item.active {
  border-color: rgba(102, 247, 209, 0.42);
  background: linear-gradient(180deg, rgba(72, 213, 167, 0.86), rgba(31, 100, 75, 0.96));
  box-shadow: 0 0 24px rgba(102, 247, 209, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.16);
}

.blade-nav-icon {
  width: 28px;
  height: 28px;
  display: grid;
  place-items: center;
  border-radius: 9px;
  background: rgba(255, 255, 255, 0.06);
  color: #f7fffc;
  font-size: 0.82rem;
  font-weight: 900;
}

.blade-nav-label {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 0.92rem;
}

@keyframes bladePageIn {
  from {
    opacity: 0.2;
    transform: translateX(18px) scale(0.99);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

.blade-ui-shell.blade-move-right .blade-page.active {
  animation: bladeSlideFromRight 300ms cubic-bezier(0.18, 0.86, 0.28, 1);
}

.blade-ui-shell.blade-move-left .blade-page.active {
  animation: bladeSlideFromLeft 300ms cubic-bezier(0.18, 0.86, 0.28, 1);
}

@keyframes bladeSlideFromRight {
  from {
    opacity: 0.24;
    transform: translateX(64px) scale(0.985);
    filter: blur(4px);
  }
}

@keyframes bladeSlideFromLeft {
  from {
    opacity: 0.24;
    transform: translateX(-64px) scale(0.985);
    filter: blur(4px);
  }
}

