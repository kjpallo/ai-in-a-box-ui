(() => {
  let elements = {};
  let audio = null;
  let lastQuestion = '';

  function init(options = {}) {
    elements = options.elements || {};
    audio = options.audio || null;

    setupTeacherToggle();
    setupPromptChips();
    setupCopyButton();
    setupClearButton();
  }

  function setupTeacherToggle() {
    const { teacherToggle } = elements;
    if (!teacherToggle) return;

    teacherToggle.addEventListener('change', () => {
      document.body.classList.toggle('teacher-mode', teacherToggle.checked);
    });
  }

  function setupPromptChips() {
    const { chipButtons, messageInput } = elements;
    if (!chipButtons || !messageInput) return;

    chipButtons.forEach((button) => {
      button.addEventListener('click', () => {
        messageInput.value = button.dataset.prompt || button.textContent.trim();
        messageInput.focus();
      });
    });
  }

  function setupCopyButton() {
    const { copyButton, responseText } = elements;
    if (!copyButton || !responseText) return;

    copyButton.addEventListener('click', async () => {
      const text = responseText.textContent.trim();
      if (!text || text === 'Ask a question to see the answer here.') return;

      try {
        await navigator.clipboard.writeText(text);
        copyButton.textContent = 'Copied';
      } catch {
        copyButton.textContent = 'Copy failed';
      }

      window.setTimeout(() => {
        copyButton.textContent = 'Copy Answer';
      }, 1200);
    });
  }

  function setupClearButton() {
    const { clearButton, responseText, messageInput } = elements;
    if (!clearButton || !responseText || !messageInput) return;

    clearButton.addEventListener('click', () => {
      if (audio) {
        audio.stop({ keepStatus: true });
        audio.setOrbSpeaking(false);
      }

      responseText.textContent = 'Ask a question to see the answer here.';
      responseText.classList.remove('streaming', 'has-answer');

      messageInput.value = '';
      messageInput.focus();

      setStreamStatus('Ready');
      setConnectionStatus('Ready');
      setVoiceStatus('Ready');
    });
  }

  function recordQuestion(question) {
    lastQuestion = String(question || '').trim();
  }

  function clearPendingAnswer() {
    // The current answer is read from the answer box when the server finishes.
  }

  function finishAnswer(answer) {
    const cleanAnswer = String(answer || '').trim();
    if (lastQuestion && cleanAnswer) {
      addHistoryItem(lastQuestion, cleanAnswer);
    }
  }

  function recordError(answer) {
    const cleanAnswer = String(answer || '').trim();
    if (lastQuestion && cleanAnswer) {
      addHistoryItem(lastQuestion, cleanAnswer);
    }
  }

  function setConnectionStatus(text) {
    setStatus(elements.connectionStatus, text);
  }

  function setStreamStatus(text) {
    setStatus(elements.streamStatus, text);
  }

  function setStatus(element, text) {
    if (!element) return;

    const friendly = normalizeStatus(text);

    element.textContent = friendly;
    element.classList.remove('status-ready', 'status-thinking', 'status-speaking', 'status-error');

    if (friendly === 'Ready') element.classList.add('status-ready');
    if (friendly === 'Thinking…') element.classList.add('status-thinking');
    if (friendly === 'Speaking…') element.classList.add('status-speaking');
    if (friendly === 'Voice problem') element.classList.add('status-error');
  }

  function normalizeStatus(text) {
    const value = String(text || '').toLowerCase();

    if (
      value.includes('speak') ||
      value.includes('talk') ||
      value.includes('stream') ||
      value.includes('queued')
    ) {
      return 'Speaking…';
    }

    if (value.includes('think') || value.includes('prepar')) {
      return 'Thinking…';
    }

    if (
      value.includes('error') ||
      value.includes('offline') ||
      value.includes('failed') ||
      value.includes('problem')
    ) {
      return 'Voice problem';
    }

    return 'Ready';
  }

  function setVoiceStatus(text) {
    const { voiceStatus } = elements;
    if (!voiceStatus) return;

    voiceStatus.textContent = normalizeVoiceText(text);
  }

  function normalizeVoiceText(text) {
    const value = String(text || '').toLowerCase();

    if (value.includes('problem') || value.includes('error') || value.includes('issue')) {
      return 'Voice problem';
    }

    if (
      value.includes('speak') ||
      value.includes('talk') ||
      value.includes('stream') ||
      value.includes('queued')
    ) {
      return 'Speaking…';
    }

    if (value.includes('think') || value.includes('prepar')) {
      return 'Thinking…';
    }

    if (value.includes('stopped')) {
      return 'Voice stopped.';
    }

    return 'Ready for the next question.';
  }

  function addHistoryItem(question, answer) {
    const { historyList } = elements;
    if (!historyList || !question || !answer) return;

    const empty = historyList.querySelector('.history-empty');
    if (empty) empty.remove();

    const card = document.createElement('article');
    card.className = 'history-card';

    const q = document.createElement('p');
    q.className = 'history-question';
    q.textContent = `Student: ${question}`;

    const a = document.createElement('p');
    a.className = 'history-answer';

    const shortAnswer = answer.replace(/\s+/g, ' ').trim();
    a.textContent = `Charlemagne: ${
      shortAnswer.length > 180 ? shortAnswer.slice(0, 177) + '...' : shortAnswer
    }`;

    card.appendChild(q);
    card.appendChild(a);
    historyList.prepend(card);

    historyList.querySelectorAll('.history-card').forEach((item, index) => {
      if (index >= 6) item.remove();
    });
  }

  window.CharlemagneTeacherUi = {
    init,
    recordQuestion,
    clearPendingAnswer,
    finishAnswer,
    recordError,
    setConnectionStatus,
    setStreamStatus,
    setVoiceStatus
  };
})();
